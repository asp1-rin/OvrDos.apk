<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#121212">

    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OvrDos Control Panel"
        android:textColor="#FF0000"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="30dp" />

    <TextView
        android:id="@+id/fov_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FOV Radius: 150"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_marginBottom="10dp" />

    <SeekBar
        android:id="@+id/fov_slider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="500"
        android:progress="150"
        android:progressDrawable="@android:color/holo_red_light"
        android:thumbTint="#FF0000"
        android:layout_marginBottom="40dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="[안내]\n1. 게임 실행 후 앱을 켜주세요.\n2. 슬라이더로 에임봇 작동 범위를 조절하세요.\n3. 원 안의 적만 자동으로 조준합니다."
        android:textColor="#888888"
        android:textSize="14sp"
        android:lineSpacingExtra="5dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Optimization Service Running..."
        android:textColor="#00FF00"
        android:textSize="12sp"
        android:layout_gravity="center_horizontal" />

</LinearLayout>
