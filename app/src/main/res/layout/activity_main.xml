<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OvrDos Ultimate Control"
        android:textColor="#FF0000"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="30dp" />

    <TextView
        android:id="@+id/fov_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FOV Radius: 150"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <SeekBar
        android:id="@+id/fov_slider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="500"
        android:progress="150"
        android:layout_marginBottom="25dp"
        android:thumbTint="#FF0000" />

    <TextView
        android:id="@+id/smooth_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smoothing: 1.0 (Snap)"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <SeekBar
        android:id="@+id/smooth_slider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="50"
        android:progress="1"
        android:layout_marginBottom="40dp"
        android:thumbTint="#00CCFF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="[Setting Guide]\n- FOV: 원 안의 적만 조준합니다.\n- Smoothing: 낮을수록 즉시 고정(빡고), 높을수록 부드럽게 이동(합법)."
        android:textColor="#777777"
        android:textSize="13sp" />

</LinearLayout>
